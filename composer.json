{
    "name"       : "oasis/doctrine-addon",
    "description": "Doctrine add-ons",
    "type"       : "library",
    "require"    : {
        "oasis/logging": "^1.1",
        "doctrine/orm" : "^2.7",
        "doctrine/annotations": "^1.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5",
        "symfony/cache": "^5.4"
    },
    "autoload"   : {
        "psr-4": {
            "Oasis\\Mlib\\Doctrine\\"           : "src/",
            "Oasis\\Mlib\\Doctrine\\Ut\\"       : "ut/",
            "Oasis\\Mlib\\Doctrine\\Ut\\Entity\\": "ut/Entity/",
            "Oasis\\Mlib\\Doctrine\\Ut\\Test\\"  : "ut/Test/"
        }
    },
